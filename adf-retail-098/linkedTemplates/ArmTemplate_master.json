{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-retail-098"
		},
		"LS_ADLSGen2_Retail_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://retailadls098.dfs.core.windows.net/"
		},
		"LS_AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://retailkart-kv.vault.azure.net/"
		},
		"LS_AzureSQL_Retail_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "retailkart-server.database.windows.net"
		},
		"LS_AzureSQL_Retail_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "retailkart"
		},
		"LS_AzureSQL_Retail_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"LS_AzureDatabricks_Notebook_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0520-062549-1wk15keq"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-retail-098_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLSGen2_Retail_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLSGen2_Retail_properties_typeProperties_url')]"
					},
					"LS_AzureKeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_AzureKeyVault_properties_typeProperties_baseUrl')]"
					},
					"LS_AzureSQL_Retail_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_Retail_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_Retail_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_Retail_properties_typeProperties_database')]"
					},
					"LS_AzureSQL_Retail_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSQL_Retail_properties_typeProperties_userName')]"
					},
					"LS_AzureDatabricks_Notebook_properties_typeProperties_existingClusterId": {
						"value": "[parameters('LS_AzureDatabricks_Notebook_properties_typeProperties_existingClusterId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}